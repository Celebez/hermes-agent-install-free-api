# Template .env — copy jadi ~/.hermes/.env dan isi API key lo
# JANGAN commit ~/.hermes/.env ke Git (sudah di .gitignore)
#
# Cara pakai:
#   1. cp .env.example ~/.hermes/.env
#   2. Edit ~/.hermes/.env, isi API key yang lo punya
#   3. Jalankan: hermes setup

# ─── Top 3 Provider (recommended setup) ──────────────────

# Groq (unlimited free tier, paling cepat)
# Signup: https://console.groq.com/keys
GROQ_API_KEY=gsk_PASTE_YOUR_KEY_HERE

# NVIDIA NIM (1000 req/bulan, kualitas tinggi)
# Signup: https://build.nvidia.com
NVIDIA_API_KEY=nvapi-PASTE_YOUR_KEY_HERE

# Cloudflare Workers AI (10K req/hari)
# Signup: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=PASTE_YOUR_TOKEN_HERE
CLOUDFLARE_ACCOUNT_ID=PASTE_YOUR_ACCOUNT_ID

# ─── Optional Providers ──────────────────────────────────

# OpenRouter (100+ model)
# Signup: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-PASTE_YOUR_KEY_HERE

# Google AI Studio (Gemini)
# Signup: https://aistudio.google.com/apikey
GOOGLE_API_KEY=PASTE_YOUR_KEY_HERE
# Atau pakai: GEMINI_API_KEY=...

# Cerebras (1M tokens/hari)
# Signup: https://inference.cerebras.ai
CEREBRAS_API_KEY=PASTE_YOUR_KEY_HERE

# Mistral AI
# Signup: https://console.mistral.ai
MISTRAL_API_KEY=PASTE_YOUR_KEY_HERE

# Cohere
# Signup: https://dashboard.cohere.ai/api-keys
COHERE_API_KEY=PASTE_YOUR_KEY_HERE

# Hugging Face
# Signup: https://huggingface.co/settings/tokens
HF_TOKEN=hf_PASTE_YOUR_TOKEN_HERE

# ─── Specialized (Voice/Search/Scraping) ─────────────────

# Deepgram (STT/TTS)
# Signup: https://console.deepgram.com
DEEPGRAM_API_KEY=PASTE_YOUR_KEY_HERE

# ElevenLabs (TTS)
# Signup: https://elevenlabs.io
ELEVENLABS_API_KEY=PASTE_YOUR_KEY_HERE

# Tavily (AI web search)
# Signup: https://tavily.com
TAVILY_API_KEY=tvly-PASTE_YOUR_KEY_HERE

# Firecrawl (web scraping)
# Signup: https://firecrawl.dev
FIRECRAWL_API_KEY=fc-PASTE_YOUR_KEY_HERE

# ─── Messaging Platform (untuk gateway) ──────────────────

# Telegram bot
# Bikin: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=PASTE_YOUR_BOT_TOKEN

# Discord bot
# Bikin: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=PASTE_YOUR_BOT_TOKEN
